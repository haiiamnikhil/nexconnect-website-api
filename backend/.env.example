# ============================================================
# NexConnect Backend – Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (PostgreSQL) ---
# Must match what was set in setup-server.sh / PostgreSQL
POSTGRES_USER=nexconnect_admin
POSTGRES_PASSWORD=YourSecurePassword!
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexconnect_db

# --- JWT Authentication ---
# Generate a strong random key:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# Token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://nex-connect.in,https://www.nex-connect.in
